{
  "schema_version": 1,
  "name": "hiwonder_rrc",
  "parameters": {
    "gear_ratio": {
      "label": "Motor Gear Ratio",
      "description": "Motor-shaft to output-shaft reduction (N:1) for the brushed-motor channels. SPEED commands are in output rad/s.",
      "type": "number",
      "default": 1.0,
      "min": 0.0001
    },
    "pulse_min_us": {
      "label": "PWM Servo Pulse Min (µs)",
      "type": "number",
      "default": 500
    },
    "pulse_max_us": {
      "label": "PWM Servo Pulse Max (µs)",
      "type": "number",
      "default": 2500
    },
    "pwm_angle_min_rad": {
      "label": "PWM Servo Angle Min (rad)",
      "type": "number",
      "default": -1.5708
    },
    "pwm_angle_max_rad": {
      "label": "PWM Servo Angle Max (rad)",
      "type": "number",
      "default": 1.5708
    },
    "raw_min": {
      "label": "Bus Servo Raw Min",
      "type": "number",
      "default": 0
    },
    "raw_max": {
      "label": "Bus Servo Raw Max",
      "type": "number",
      "default": 1000
    },
    "bus_angle_min_rad": {
      "label": "Bus Servo Angle Min (rad)",
      "type": "number",
      "default": -2.0944
    },
    "bus_angle_max_rad": {
      "label": "Bus Servo Angle Max (rad)",
      "type": "number",
      "default": 2.0944
    }
  },
  "drivers": [
    {
      "name": "hiwonder_rrc_board",
      "class": "hiwonder_rrc_adapter.board_adapter:HiwonderRRCBoardAdapter",
      "iotype_compat": ["imu", "battery"],
      "parameters": {
        "device": {
          "label": "Serial Device",
          "description": "USB serial path for the RRC board.",
          "type": "string",
          "default": "/dev/ttyACM0"
        },
        "baud": {
          "label": "Baud Rate",
          "description": "RRC Lite firmware runs USART1 at 115200 baud over the on-board WCH USB bridge.",
          "type": "number",
          "default": 115200
        },
        "poll_hz": {
          "label": "Queue Poll Rate (Hz)",
          "description": "Rate at which the adapter drains IMU/battery queues and republishes as PRP state.",
          "type": "number",
          "default": 100,
          "min": 1
        },
        "battery_cells": {
          "label": "Battery Cell Count",
          "description": "Series cell count — used only to populate BatteryState.cell_voltage length.",
          "type": "number",
          "default": 3
        }
      }
    },
    {
      "name": "hiwonder_rrc_motor",
      "class": "hiwonder_rrc_adapter.motor_adapter:HiwonderRRCMotorAdapter",
      "iotype_compat": ["joint"],
      "host_hint": "hiwonder_rrc_board",
      "parameters": {
        "port": {
          "label": "Motor Port",
          "description": "RRC motor channel (1–4).",
          "type": "number",
          "min": 1,
          "max": 4,
          "required": true
        },
        "state_hz": {
          "label": "State Publish Rate (Hz)",
          "description": "MotorState publish rate. measured_value is sourced from the firmware's 20 Hz motor-state telemetry (counter + rps); both read 0 until the encoder hardware is fixed.",
          "type": "number",
          "default": 10,
          "min": 0
        },
        "debug_log": {
          "label": "Debug Log Writes",
          "description": "Log every PWM/stop packet sent to the RRC board. Useful for diagnosing motor stop/start behaviour; noisy in steady-state teleop.",
          "type": "boolean",
          "default": false
        }
      }
    },
    {
      "name": "hiwonder_rrc_pwm_servo",
      "class": "hiwonder_rrc_adapter.pwm_servo_adapter.HiwonderRRCPWMServoAdapter",
      "iotype_compat": ["joint"],
      "host_hint": "hiwonder_rrc_board",
      "parameters": {
        "channel": {
          "label": "PWM Channel",
          "description": "RRC PWM servo channel (1–4).",
          "type": "number",
          "min": 1,
          "max": 4,
          "required": true
        },
        "default_duration_ms": {
          "label": "Default Duration (ms)",
          "description": "Used when a ServoCommand has duration == 0.",
          "type": "number",
          "default": 20
        },
        "state_hz": {
          "label": "State Publish Rate (Hz)",
          "type": "number",
          "default": 10,
          "min": 0
        }
      }
    },
    {
      "name": "hiwonder_rrc_bus_servo",
      "class": "hiwonder_rrc_adapter.bus_servo_adapter.HiwonderRRCBusServoAdapter",
      "iotype_compat": ["joint"],
      "host_hint": "hiwonder_rrc_board",
      "parameters": {
        "servo_id": {
          "label": "Bus Servo ID",
          "description": "LX-series servo ID on the bus (1–253).",
          "type": "number",
          "min": 1,
          "max": 253,
          "required": true
        },
        "default_duration_ms": {
          "label": "Default Duration (ms)",
          "type": "number",
          "default": 200
        },
        "state_hz": {
          "label": "State Publish Rate (Hz)",
          "type": "number",
          "default": 5,
          "min": 0
        }
      }
    }
  ]
}
