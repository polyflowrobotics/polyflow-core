{
  "type": "controller",
  "name": "Motor Controller",
  "entry_point": "motor_controller/node.py",
  "topics": [
    {
      "name": "command",
      "direction": "subscribe",
      "msg_type": "std_msgs/Float64"
    }
  ],
  "services": [],
  "actions": [],
  "parameters_schema": {
    "motor_id": {
      "label": "Motor ID",
      "type": "number",
      "default": 1,
      "description": "Motor port ID (1-indexed) on the controller board.",
      "ui": { "group": "Motor", "order": 1 }
    },
    "max_speed": {
      "label": "Max Speed",
      "type": "number",
      "default": 1.0,
      "description": "Maximum allowable speed value.",
      "ui": { "group": "Motor", "order": 2 }
    }
  },
  "defaults": {
    "rate_hz": 50
  }
}
